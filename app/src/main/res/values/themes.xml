<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Flowly" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">#0D1117</item>
        <!-- Use clear animated icon to avoid pixelation -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Flowly</item>
    </style>
</resources>